DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotlet
BETTER_AUTH_SECRET=change-me-min-32-chars-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

CF_EMAIL_API_TOKEN=replace
EMAIL_FROM=noreply@your-verified-domain.com
EMAIL_FROM_NAME=dotlet

# STORAGE_PROVIDER can be s3 or r2
STORAGE_PROVIDER=s3

# S3
S3_BUCKET=dotlet
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace
S3_SECRET_ACCESS_KEY=replace

# R2
CF_ACCOUNT_ID=replace
R2_BUCKET=dotlet
R2_ACCESS_KEY_ID=replace
R2_SECRET_ACCESS_KEY=replace
