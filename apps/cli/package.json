{
  "name": "dotlet",
  "version": "0.1.2",
  "description": "CLI for syncing and versioning dotfiles with devices",
  "keywords": [
    "dotfiles",
    "cli",
    "sync",
    "config",
    "developer-tools"
  ],
  "homepage": "https://dotlet.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamilkotta/dotlet.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/shamilkotta/dotlet/issues"
  },
  "author": "Shamil",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "bin": {
    "dotlet": "./dist/index.js",
    "dot": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean --env.DOTLET_BASE_URL https://dotlet.app",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --clean --watch --env.DOTLET_BASE_URL http://localhost:3000",
    "lint": "oxlint src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@effect/cli": "0.75.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-node": "0.106.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "effect": "3.21.0",
    "figures": "^6.1.0",
    "log-symbols": "^7.0.1",
    "open": "^10.2.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.34",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
